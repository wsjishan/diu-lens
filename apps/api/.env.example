APP_NAME=DIU Lens API
APP_VERSION=0.1.0
APP_ENV=production
ALLOWED_ORIGINS=https://www.diulens.app,https://diulens.app
DATABASE_URL=postgresql://diu_user:strongpassword@localhost:5432/diu_lens
JWT_SECRET=super_secret_key_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
FACE_MATCH_DISTANCE_THRESHOLD=0.38
FACE_MATCH_TOP_K=5
FACE_MATCH_CANDIDATE_POOL_LIMIT=200
INSIGHTFACE_MODEL_PACK=antelopev2
INSIGHTFACE_ROOT=/app/.insightface
BIOMETRIC_STARTUP_VALIDATION=true
STORAGE_PATH=/var/lib/diu-lens/storage
